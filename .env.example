# Bot User OAuth Token — from Slack app's "OAuth & Permissions" page (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token — from Slack app's "Basic Information" → "App-Level Tokens" (starts with xapp-)
# Required for Socket Mode. Must have the "connections:write" scope.
SLACK_APP_TOKEN=xapp-your-app-token-here

# Strongly recommended — restrict who can talk to the bot, by Slack user ID
# (comma-separated). Without this, anyone in the workspace can DM the bot.
# Find your member ID in Slack: avatar → Profile → ⋯ → Copy member ID.
# ALLOWED_USERS=U0123ABCD,U0456EFGH

# Optional — restrict bot to specific channel IDs (comma-separated). Leave empty to allow all.
# ALLOWED_CHANNELS=C0123ABCD,C0456EFGH

# Optional — working directory for the Claude Code session. Defaults to current dir.
# CLAUDE_CWD=/Users/you/projects/your-project

# Optional — set to "trusted" to allow Bash/Edit/Write/NotebookEdit. Default is
# safe mode, which blocks those tools. Only enable in a working directory you
# trust the agent (and anyone who can DM/@mention the bot) to operate in.
# MODE=trusted

# Optional — per-turn timeout in milliseconds. Default 300000 (5 minutes).
# AGENT_TIMEOUT_MS=300000

# Optional — path to the JSON file that persists per-channel SDK session ids
# so context survives a restart. Default ".sessions.json" in the cwd.
# SESSIONS_FILE=/var/lib/claude-slack-bridge/sessions.json
