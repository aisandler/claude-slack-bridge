# Bot User OAuth Token — from Slack app's "OAuth & Permissions" page (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token — from Slack app's "Basic Information" → "App-Level Tokens" (starts with xapp-)
# Required for Socket Mode. Must have the "connections:write" scope.
SLACK_APP_TOKEN=xapp-your-app-token-here

# Optional — restrict bot to specific channel IDs (comma-separated). Leave empty to allow all.
# ALLOWED_CHANNELS=C0123ABCD,C0456EFGH

# Optional — working directory for the Claude Code session. Defaults to current dir.
# CLAUDE_CWD=/Users/you/projects/your-project
